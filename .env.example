# ============================================================
# Econofi Agents Core — Environment Variables
# Copy this file to .env and fill in values for your environment
# NEVER commit .env to version control
# ============================================================

# -----------------------------------------------------------
# Node / Runtime
# -----------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# -----------------------------------------------------------
# Anthropic / Claude API
# -----------------------------------------------------------
# Required: Claude API key for all agent operations
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------
# Supabase (PostgreSQL + Auth + RLS)
# -----------------------------------------------------------
# Project URL from Supabase dashboard -> Settings -> API
SUPABASE_URL=https://your-project.supabase.co

# Service role key (bypasses RLS — server-side only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anon key (for client-safe operations, respects RLS)
SUPABASE_ANON_KEY=eyJ...

# Direct PostgreSQL connection string (for migrations and admin ops)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------
# FFIEC Geocoding API (CRA census tract validation)
# -----------------------------------------------------------
# FFIEC geocoding API base URL
FFIEC_GEOCODE_API_URL=https://geomap.ffiec.gov/FFIECGeocMap/GeocodeMap1.aspx

# Optional: API key if FFIEC issues one (currently public, no key required)
FFIEC_API_KEY=

# FFIEC API timeout in milliseconds
FFIEC_API_TIMEOUT_MS=5000

# -----------------------------------------------------------
# AWS (Document storage for exception reports + narratives)
# -----------------------------------------------------------
AWS_REGION=us-east-1
AWS_S3_BUCKET=econofi-compliance-documents
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# -----------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------
# Secret for signing JWTs — minimum 32 chars, use a random string
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRY=8h

# -----------------------------------------------------------
# CRA Feature Flag
# -----------------------------------------------------------
# Controls which CRA evaluation framework is used
# '1995_legacy' = pre-2023 CRA rules (most community banks)
# '2023_modern' = updated CRA rules (effective Jan 1, 2026 for large banks)
CRA_FRAMEWORK=1995_legacy

# -----------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
